{
  "name": "dotfiles-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "mounts": [
    // Optional: mount a local chezmoi-recipes binary to override the image-installed one.
    // Useful when developing chezmoi-recipes alongside this repo.
    // "source=${localEnv:HOME}/projects/oss/chezmoi-recipes/bin/chezmoi-recipes,target=/usr/local/bin/chezmoi-recipes,type=bind,readonly"
  ],
  "remoteUser": "vscode",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "bash /workspace/.devcontainer/init.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "foxundermoon.shell-format",
        "timonwong.shellcheck"
      ]
    }
  }
}
